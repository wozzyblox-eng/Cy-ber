local function saveConfig()
    pcall(function()
        if writefile then
            local data = {
                NORMAL_SPEED = NORMAL_SPEED,
                SLOW_SPEED = SLOW_SPEED,
                STEAL_RADIUS = STEAL_RADIUS,
